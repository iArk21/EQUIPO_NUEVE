<?xml version="1.0" encoding="utf-8"?>
<!--
    ANIMACIÓN DE LA BOTELLA - Splash (HU 1.0 Criterio 2)
    DIFERENTE al otro equipo:
    - El otro equipo: rotación simple 360° + scale básico
    - Este equipo: animación de "flotación" con balanceo lateral + rebote suave
      Simula una botella flotando/meciéndose, más cartoon y divertida
    - Duración del balanceo: 1800ms (distinto al 2000ms del otro)
    - El efecto de "respiración" tiene un rango diferente (0.85 a 1.05 vs 0.8 a 1.1)
-->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@android:anim/accelerate_decelerate_interpolator"
    android:shareInterpolator="false">

    <!--
        Balanceo lateral (como una botella que se mece)
        El otro equipo NO tiene esto - es su diferenciador más notable
    -->
    <rotate
        android:fromDegrees="-12"
        android:toDegrees="12"
        android:pivotX="50%"
        android:pivotY="80%"
        android:duration="900"
        android:repeatMode="reverse"
        android:repeatCount="infinite"
        android:interpolator="@android:anim/anticipate_overshoot_interpolator" />

    <!--
        Efecto de flotación vertical (sube y baja suavemente)
        Da sensación de que la botella está "viva"/cartoon
    -->
    <translate
        android:fromYDelta="-8dp"
        android:toYDelta="8dp"
        android:duration="1800"
        android:repeatMode="reverse"
        android:repeatCount="infinite"
        android:interpolator="@android:anim/decelerate_interpolator" />

    <!--
        Escala sutil - rango diferente al otro equipo
        0.90 a 1.05 (vs 0.8 a 1.1 del otro equipo)
    -->
    <scale
        android:fromXScale="0.90"
        android:toXScale="1.05"
        android:fromYScale="0.90"
        android:toYScale="1.05"
        android:pivotX="50%"
        android:pivotY="50%"
        android:duration="1800"
        android:repeatMode="reverse"
        android:repeatCount="infinite"
        android:interpolator="@android:anim/decelerate_interpolator" />

</set>
