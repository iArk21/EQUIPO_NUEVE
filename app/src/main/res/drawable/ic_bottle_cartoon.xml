    <path
        android:fillColor="#30FFFFFF"
        android:pathData="M44,62 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0" />
    <path
        android:fillColor="#30FFFFFF"
        android:pathData="M57,58 m-2,0 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0" />
    <path
        android:fillColor="#30FFFFFF"
        android:pathData="M48,72 m-2,0 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0" />

</vector>
