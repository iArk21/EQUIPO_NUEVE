<?xml version="1.0" encoding="utf-8"?>
<!--
    ÍCONO DE BOTELLA - ESTILO CARTOON/DIVERTIDO
    Color: #FF6D00 (naranja vibrante del equipo)
    Diferente al ic_bottle.xml del otro equipo (que era una botella genérica simple)
    Esta botella tiene: cuerpo redondeado cartoon, cuello pronunciado, tapón, brillo y base
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="120dp"
    android:height="120dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Sombra/base de la botella -->
    <path
        android:fillColor="#33000000"
        android:pathData="M35,90 Q50,95 65,90 Q60,93 50,93 Q40,93 35,90z" />

    <!-- Cuerpo principal de la botella (cartoon, redondeado) -->
    <path
        android:fillColor="#FFFF6D00"
        android:pathData="M30,55 Q28,45 30,35 Q32,28 38,26 L38,22 Q38,18 42,17 L58,17 Q62,18 62,22 L62,26 Q68,28 70,35 Q72,45 70,55 Q68,70 65,78 Q62,85 50,86 Q38,85 35,78 Q32,70 30,55z" />

    <!-- Tapón de la botella -->
