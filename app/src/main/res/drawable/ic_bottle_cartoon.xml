        android:fillColor="#40FFFFFF"
        android:pathData="M36,38 Q34,48 36,58 Q37,64 39,68 Q37,58 37,48 Q37,42 38,36 Q37,37 36,38z" />

    <!-- Brillo superior pequeño -->
