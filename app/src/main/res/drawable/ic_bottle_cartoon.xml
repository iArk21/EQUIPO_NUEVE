        android:fillColor="#FF000000"
        android:pathData="M40,14 Q40,10 50,10 Q60,10 60,14 L62,18 Q62,20 58,20 L42,20 Q38,20 38,18z" />

    <!-- Brillo lateral izquierdo (efecto cartoon) -->
