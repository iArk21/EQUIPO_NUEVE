        android:fillColor="#FFFFFFFF"
        android:pathData="M34,52 Q33,48 34,44 Q35,42 50,42 Q65,42 66,44 Q67,48 66,52 Q65,56 50,56 Q35,56 34,52z" />

    <!-- Texto de la etiqueta: líneas decorativas cartoon -->
    <path
        android:fillColor="#FFFF6D00"
        android:pathData="M38,47 L62,47"
        android:strokeColor="#FFFF6D00"
        android:strokeWidth="1.5" />
    <path
        android:fillColor="#FFFF6D00"
        android:pathData="M40,50 L60,50"
        android:strokeColor="#FFFF6D00"
        android:strokeWidth="1.5" />
    <path
        android:fillColor="#FFFF6D00"
        android:pathData="M42,53 L58,53"
        android:strokeColor="#FFFF6D00"
        android:strokeWidth="1.5" />

    <!-- Borde oscuro del cuerpo (estilo cartoon outline) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#CC000000"
        android:strokeWidth="2"
        android:pathData="M30,55 Q28,45 30,35 Q32,28 38,26 L38,22 Q38,18 42,17 L58,17 Q62,18 62,22 L62,26 Q68,28 70,35 Q72,45 70,55 Q68,70 65,78 Q62,85 50,86 Q38,85 35,78 Q32,70 30,55z" />

