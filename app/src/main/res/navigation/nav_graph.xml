<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.pico_botella.ui.splash.SplashFragment"
        android:label="SplashFragment"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splashFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.pico_botella.ui.home.HomeFragment"
        android:label="HomeFragment"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/ratingFragment"
        android:name="com.example.pico_botella.ui.rating.RatingFragment"
        android:label="RatingFragment"
        tools:layout="@layout/fragment_rating" />

    <fragment
        android:id="@+id/instructionsFragment"
        android:name="com.example.pico_botella.ui.instructions.InstructionsFragment"
        android:label="InstructionsFragment"
        tools:layout="@layout/fragment_instructions" />

    <fragment
        android:id="@+id/challengesFragment"
        android:name="com.example.pico_botella.ui.challenges.ChallengesFragment"
        android:label="ChallengesFragment"
        tools:layout="@layout/fragment_challenges" />

    <fragment
        android:id="@+id/shareFragment"
        android:name="com.example.pico_botella.ui.share.ShareFragment"
        android:label="ShareFragment"
        tools:layout="@layout/fragment_share" />

</navigation>