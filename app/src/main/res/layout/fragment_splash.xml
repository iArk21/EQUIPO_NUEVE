<?xml version="1.0" encoding="utf-8"?>
<!--
    FRAGMENT SPLASH - HU 1.0
    Muestra el logo de la aplicación con una animación de entrada.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_splash">

    <!--
        FONDO DECORATIVO: círculo naranja sutil detrás de la botella
    -->
    <View
        android:id="@+id/viewGlowCircle"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_glow_circle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.42" />

    <!--
        ÍCONO DE BOTELLA - Usando el logo de la app (HU 1.0 Criterio 2 actualizado)
        ID: ivBottleCartoon (mantenido para compatibilidad con el código Kotlin)
    -->
    <ImageView
        android:id="@+id/ivBottleCartoon"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:contentDescription="@string/splash_bottle_desc"
        android:src="@mipmap/imagen_foreground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.42" />

    <!--
        TÍTULO DEL JUEGO
    -->
    <TextView
        android:id="@+id/tvTituloJuego"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/splash_titulo"
        android:textColor="@color/orange_pico"
        android:textSize="36sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:shadowColor="@color/orange_pico_dark"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="8"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivBottleCartoon" />

    <!--
        SUBTÍTULO DECORATIVO
    -->
    <TextView
        android:id="@+id/tvSubtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/compartir_eslogan"
        android:textColor="#66FF6D00"
        android:textSize="13sp"
        android:letterSpacing="0.15"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTituloJuego" />

</androidx.constraintlayout.widget.ConstraintLayout>