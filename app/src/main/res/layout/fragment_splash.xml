<?xml version="1.0" encoding="utf-8"?>
<!--
    FRAGMENT SPLASH - HU 1.0
    DIFERENCIAS vs otro equipo:
    - Fondo: Negro puro (igual al criterio) PERO con un sutil gradiente radial mediante shape
    - Botella: usa ic_bottle_cartoon en lugar de ic_bottle simple
    - Texto: naranja vibrante #FF6D00 (no #FF9800), fuente más grande (36sp vs 32sp)
    - Texto tiene sombra para mayor impacto visual
    - Variable del ImageView: ivBottleCartoon (renombrada)
    - Variable del TextView: tvTituloJuego (renombrada)
    - Layout tiene padding decorativo diferente
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_splash">

    <!--
        FONDO DECORATIVO: círculo naranja muy sutil detrás de la botella
        Da profundidad y distingue visualmente del otro equipo
    -->
    <View
        android:id="@+id/viewGlowCircle"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_glow_circle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.42" />

    <!--
        ÍCONO DE BOTELLA CARTOON - HU 1.0 Criterio 2
        ID renombrado: ivBottleCartoon (antes era ivBottle)
        Usa el nuevo drawable ic_bottle_cartoon
        Tamaño: 160dp (antes 150dp) - sutilmente más grande
    -->
    <ImageView
        android:id="@+id/ivBottleCartoon"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:contentDescription="@string/splash_bottle_desc"
        android:src="@drawable/ic_bottle_cartoon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.42" />

    <!--
        TÍTULO DEL JUEGO - HU 1.0 Criterio 3
        ID renombrado: tvTituloJuego (antes era tvAppName)
        Color: @color/orange_pico = #FF6D00 (antes era #FF9800)
        Tamaño: 36sp (antes 32sp)
        Sombra: naranja oscuro para efecto de profundidad
        Letra spacing y estilo diferentes
    -->
    <TextView
        android:id="@+id/tvTituloJuego"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/splash_titulo"
        android:textColor="@color/orange_pico"
        android:textSize="36sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:shadowColor="@color/orange_pico_dark"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="8"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivBottleCartoon" />

    <!--
        SUBTÍTULO DECORATIVO (diferencia adicional visual)
        No está en el otro equipo
    -->
    <TextView
        android:id="@+id/tvSubtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="el juego de los valientes"
        android:textColor="#66FF6D00"
        android:textSize="13sp"
        android:letterSpacing="0.15"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTituloJuego" />

</androidx.constraintlayout.widget.ConstraintLayout>
