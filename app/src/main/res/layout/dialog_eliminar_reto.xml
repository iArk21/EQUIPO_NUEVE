<?xml version="1.0" encoding="utf-8"?>
<!--
    DIÁLOGO ELIMINAR RETO — HU 9.0

    Criterio 1: Fondo blanco
    Criterio 2: Título "¿Desea eliminar el siguiente reto?:" — centrado, negro, bold
    Criterio 3: Texto con la descripción del reto a eliminar (viene de la BD)
    Criterio 4: Texto "NO" naranja — cierra el diálogo, regresa a HU 6.0
    Criterio 5: Texto "SI" naranja — elimina de SQLite y quita de la lista
    Criterio 6: No se cierra al tocar fuera (gestionado en el Fragment)
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/dialog_background"
    android:orientation="vertical"
    android:padding="24dp">

    <!--
        Criterio 2: Título "¿Desea eliminar el siguiente reto?:"
        centrado, negro, bold
    -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/dialogo_eliminar_titulo"
        android:textColor="@color/dialog_title_color"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!--
        Criterio 3: Descripción del reto a eliminar.
        Esta información viene de la base de datos SQLite.
        Se llena desde el Fragment con: tvDescripcionReto.text = reto.descripcion
    -->
    <TextView
        android:id="@+id/tv_descripcion_reto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:textColor="@android:color/black"
        android:textSize="15sp"
        android:fontFamily="sans-serif"
        android:text="" />

    <!--
        Criterios 4 y 5: Botones "NO" y "SI" — ambos de color naranja.
        La HU pide que sean TEXTOS (no botones rellenos), por eso se usan
        TextButton style. El texto naranja los diferencia del fondo blanco.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="end"
        android:orientation="horizontal">

        <!--
            Criterio 4: "NO" naranja.
            Al dar click cierra el diálogo y deja al usuario en HU 6.0.
        -->
        <Button
            android:id="@+id/btn_no"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dialogo_eliminar_no"
            android:textColor="@color/orange_pico"
            android:textStyle="bold"
            android:textSize="15sp" />

        <!--
            Criterio 5: "SI" naranja.
            Al dar click elimina el reto de SQLite y la lista se actualiza
            automáticamente gracias al Flow de Room en el ViewModel.
        -->
        <Button
            android:id="@+id/btn_si"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/dialogo_eliminar_si"
            android:textColor="@color/orange_pico"
            android:textStyle="bold"
            android:textSize="15sp" />

    </LinearLayout>

</LinearLayout>
